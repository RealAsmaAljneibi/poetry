{
  "model_name": "openai/whisper-small",
  "language": "ar",
  "train_jsonl": "data/processed/train.jsonl",
  "val_jsonl": "data/processed/val.jsonl",
  "test_jsonl": "data/processed/test.jsonl",
  "replay_jsonl": "data/processed/sada_train.jsonl",
  "replay_ratio": 0.25,
  "output_dir": "outputs/models/whisper_nabati_run7_replay",
  "epochs": 5,
  "batch_size": 4,
  "grad_accum_steps": 8,
  "learning_rate": 5e-06,
  "weight_decay": 0.01,
  "warmup_ratio": 0.15,
  "label_smoothing": 0.0,
  "seed": 42,
  "use_lora": true,
  "lora_rank": 4,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "lora_targets": [
    "q_proj",
    "v_proj"
  ],
  "freeze_encoder": false,
  "decoder_only_lora": false,
  "mix_ratio": 0.5,
  "optimizer": "adamw_torch",
  "lr_scheduler_type": "cosine",
  "best_model_metric": "wer",
  "spec_augment": true,
  "ocr_threshold": 0.15
}
