{
  "task": "emotion_text",
  "model_name": "faisalq/bert-base-arapoembert",
  "train_jsonl": "data/processed/train.jsonl",
  "val_jsonl": "data/processed/val.jsonl",
  "test_jsonl": "data/processed/test.jsonl",
  "output_dir": "outputs/models/arapoem_emotion",
  "max_seq_len": 32,
  "epochs": 20,
  "batch_size": 16,
  "grad_accum_steps": 4,
  "learning_rate": 3e-05,
  "weight_decay": 0.01,
  "warmup_ratio": 0.1,
  "dropout": 0.1,
  "patience": 8,
  "scheduler": "cosine",
  "seed": 42,
  "discriminative_lr_decay": 0.9,
  "gradual_unfreeze_epochs": 1,
  "use_focal_loss": false,
  "focal_gamma": 2.0,
  "emotion_merge_profile": "rare_merge_v1",
  "context_window": 1
}
